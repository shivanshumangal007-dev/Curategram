generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SavedItem {
  id          String   @id
  title       String
  description String?
  imageUrl    String?
  link        String
  tags        String[]
  createdAt   DateTime @default(now())
  userID      String
  User        User     @relation(fields: [userID], references: [id])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  gender    String?
  createdAt DateTime @default(now())

  savedItems SavedItem[]
}
